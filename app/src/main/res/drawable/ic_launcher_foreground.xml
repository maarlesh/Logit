<?xml version="1.0" encoding="utf-8"?>
<!--
  res/drawable/ic_launcher_foreground.xml
  White rounded "card" holding the rupee mark, with a saffron confirm-check bubble.
  All content sits inside the 66dp adaptive safe-zone (centre 54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- white card / token -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M47,32 h14 a7,7 0 0 1 7,7 v30 a7,7 0 0 1 -7,7 h-14 a7,7 0 0 1 -7,-7 v-30 a7,7 0 0 1 7,-7 z" />

    <!-- rupee mark (monoline, forest green) -->
    <group>
        <path android:strokeColor="#1A6B4A" android:strokeWidth="4"
            android:strokeLineCap="round" android:fillColor="#00000000"
            android:pathData="M48,40 H62" />
        <path android:strokeColor="#1A6B4A" android:strokeWidth="4"
            android:strokeLineCap="round" android:fillColor="#00000000"
            android:pathData="M48,46 H62" />
        <path android:strokeColor="#1A6B4A" android:strokeWidth="4"
            android:strokeLineCap="round" android:fillColor="#00000000"
            android:pathData="M52,46 V56" />
        <path android:strokeColor="#1A6B4A" android:strokeWidth="4"
            android:strokeLineCap="round" android:fillColor="#00000000"
            android:pathData="M52,46 C61,46 61,56 52,56" />
        <path android:strokeColor="#1A6B4A" android:strokeWidth="4"
            android:strokeLineCap="round" android:strokeLineJoin="round" android:fillColor="#00000000"
            android:pathData="M52,56 L61,69" />
    </group>

    <!-- saffron confirm bubble + checkmark -->
    <path
        android:fillColor="#E8A020"
        android:pathData="M61,38 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0" />
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M67,38 L70,41 L76,34" />
</vector>
