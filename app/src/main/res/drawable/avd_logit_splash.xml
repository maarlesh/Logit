<?xml version="1.0" encoding="utf-8"?>
<!--
  res/drawable/avd_logit_splash.xml
  Animated launch icon for the Android 12+ SplashScreen API.
  Sequence (~1.1s):
    1. Radar rings fade + scale up
    2. White card springs in (overshoot)
    3. Saffron bubble pops (overshoot)
    4. Checkmark draws on (trim path)
  Self-contained: base vector + every animator are inlined via aapt:attr,
  so this single file is all you need.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">

            <!-- radar rings -->
            <group android:name="ringGrp" android:pivotX="54" android:pivotY="54"
                android:scaleX="0.6" android:scaleY="0.6">
                <path android:name="ring1"
                    android:strokeColor="#FFFFFF" android:strokeWidth="2"
                    android:strokeAlpha="0" android:fillColor="#00000000"
                    android:pathData="M12,54 a42,42 0 1,0 84,0 a42,42 0 1,0 -84,0" />
                <path android:name="ring2"
                    android:strokeColor="#FFFFFF" android:strokeWidth="2"
                    android:strokeAlpha="0" android:fillColor="#00000000"
                    android:pathData="M21,54 a33,33 0 1,0 66,0 a33,33 0 1,0 -66,0" />
            </group>

            <!-- card + rupee (spring in together) -->
            <group android:name="cardGrp" android:pivotX="54" android:pivotY="54"
                android:scaleX="0.3" android:scaleY="0.3">
                <path android:name="card"
                    android:fillColor="#FFFFFF" android:fillAlpha="0"
                    android:pathData="M47,32 h14 a7,7 0 0 1 7,7 v30 a7,7 0 0 1 -7,7 h-14 a7,7 0 0 1 -7,-7 v-30 a7,7 0 0 1 7,-7 z" />
                <path android:name="r1" android:strokeColor="#1A6B4A" android:strokeWidth="4"
                    android:strokeLineCap="round" android:fillColor="#00000000"
                    android:pathData="M48,40 H62" />
                <path android:name="r2" android:strokeColor="#1A6B4A" android:strokeWidth="4"
                    android:strokeLineCap="round" android:fillColor="#00000000"
                    android:pathData="M48,46 H62" />
                <path android:name="r3" android:strokeColor="#1A6B4A" android:strokeWidth="4"
                    android:strokeLineCap="round" android:fillColor="#00000000"
                    android:pathData="M52,46 V56" />
                <path android:name="r4" android:strokeColor="#1A6B4A" android:strokeWidth="4"
                    android:strokeLineCap="round" android:fillColor="#00000000"
                    android:pathData="M52,46 C61,46 61,56 52,56" />
                <path android:name="r5" android:strokeColor="#1A6B4A" android:strokeWidth="4"
                    android:strokeLineCap="round" android:strokeLineJoin="round" android:fillColor="#00000000"
                    android:pathData="M52,56 L61,69" />
            </group>

            <!-- saffron confirm bubble (pops) -->
            <group android:name="checkGrp" android:pivotX="71" android:pivotY="38"
                android:scaleX="0" android:scaleY="0">
                <path android:name="bubble"
                    android:fillColor="#E8A020"
                    android:pathData="M61,38 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0" />
                <path android:name="checkmark"
                    android:strokeColor="#FFFFFF" android:strokeWidth="3.2"
                    android:strokeLineCap="round" android:strokeLineJoin="round"
                    android:fillColor="#00000000"
                    android:trimPathStart="0" android:trimPathEnd="0"
                    android:pathData="M67,38 L70,41 L76,34" />
            </group>
        </vector>
    </aapt:attr>

    <!-- rings: fade + scale -->
    <target android:name="ring1">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="strokeAlpha"
                android:valueFrom="0" android:valueTo="0.30"
                android:startOffset="0" android:duration="500"
                android:interpolator="@android:interpolator/decelerate_quint" />
        </aapt:attr>
    </target>
    <target android:name="ring2">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="strokeAlpha"
                android:valueFrom="0" android:valueTo="0.20"
                android:startOffset="120" android:duration="500"
                android:interpolator="@android:interpolator/decelerate_quint" />
        </aapt:attr>
    </target>
    <target android:name="ringGrp">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator android:propertyName="scaleX"
                    android:valueFrom="0.6" android:valueTo="1"
                    android:duration="700"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator android:propertyName="scaleY"
                    android:valueFrom="0.6" android:valueTo="1"
                    android:duration="700"
                    android:interpolator="@android:interpolator/decelerate_quint" />
            </set>
        </aapt:attr>
    </target>

    <!-- card: spring in -->
    <target android:name="cardGrp">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator android:propertyName="scaleX"
                    android:valueFrom="0.3" android:valueTo="1"
                    android:startOffset="120" android:duration="600"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator android:propertyName="scaleY"
                    android:valueFrom="0.3" android:valueTo="1"
                    android:startOffset="120" android:duration="600"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="card">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="fillAlpha"
                android:valueFrom="0" android:valueTo="1"
                android:startOffset="120" android:duration="220"
                android:interpolator="@android:interpolator/decelerate_cubic" />
        </aapt:attr>
    </target>

    <!-- bubble: pop -->
    <target android:name="checkGrp">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator android:propertyName="scaleX"
                    android:valueFrom="0" android:valueTo="1"
                    android:startOffset="500" android:duration="480"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator android:propertyName="scaleY"
                    android:valueFrom="0" android:valueTo="1"
                    android:startOffset="500" android:duration="480"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>

    <!-- checkmark: draw on -->
    <target android:name="checkmark">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="trimPathEnd"
                android:valueFrom="0" android:valueTo="1"
                android:startOffset="660" android:duration="280"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
</animated-vector>
