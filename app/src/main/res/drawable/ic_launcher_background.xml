<?xml version="1.0" encoding="utf-8"?>
<!--
  res/drawable/ic_launcher_background.xml
  Forest-green field with two faint concentric rings (the Logit "radar" motif).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- solid brand field (system masks it to the launcher shape) -->
    <path
        android:fillColor="#1A6B4A"
        android:pathData="M0,0 h108 v108 h-108 z" />

    <!-- subtle deep-green vignette ring -->
    <path
        android:strokeColor="#104F35"
        android:strokeWidth="10"
        android:strokeAlpha="0.55"
        android:fillColor="#00000000"
        android:pathData="M9,54 a45,45 0 1,0 90,0 a45,45 0 1,0 -90,0" />

    <!-- concentric white rings -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeAlpha="0.16"
        android:fillColor="#00000000"
        android:pathData="M12,54 a42,42 0 1,0 84,0 a42,42 0 1,0 -84,0" />
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeAlpha="0.12"
        android:fillColor="#00000000"
        android:pathData="M21,54 a33,33 0 1,0 66,0 a33,33 0 1,0 -66,0" />
</vector>
